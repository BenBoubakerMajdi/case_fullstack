# =============================================================================
# Matr Data Analysis Agent — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env — it is listed in .gitignore.
# =============================================================================


# =============================================================================
# Database (PostgreSQL)
# =============================================================================

# PostgreSQL connection string.
# Local development with Docker:
DATABASE_URL=postgresql+asyncpg://matr:matr@localhost:5432/matr

# Production (Railway, Supabase, etc.):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname


# =============================================================================
# AI Model Configuration
# =============================================================================

# The AI model to use in PydanticAI provider:model format.
#
# Recommended:
#   openai:gpt-4o        — best instruction following, handles all 17 prompt rules reliably
#   openai:gpt-4o-mini   — faster and cheaper, less reliable for complex multi-step queries
MODEL=openai:gpt-4o


# =============================================================================
# API Keys — fill in the key for your chosen provider
# =============================================================================

# Required if MODEL starts with "openai:"
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Required if MODEL starts with "anthropic:"
# Get your key at: https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Required if MODEL starts with "google-gla:"
# Get your key at: https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=your-google-api-key-here


# =============================================================================
# CORS Configuration (production only)
# =============================================================================

# The URL of your deployed frontend.
# Only needed in production — leave empty for local development.
# Example: https://matr.vercel.app
ALLOWED_ORIGIN=

